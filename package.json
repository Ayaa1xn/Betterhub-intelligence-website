{
  "name": "betterhub-intelligence",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node --import tsx scripts/dev.ts",
    "client": "vite --port=3000 --host=127.0.0.1 --strictPort",
    "api": "node --import tsx server/index.ts",
    "build:web": "vite build",
    "build:server": "node scripts/build-server.js",
    "build": "npm run build:web && npm run build:server",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server.js",
    "clean": "rm -rf dist dist-server",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test src/lib/router.test.ts src/lib/richText.test.ts src/lib/assistantKnowledge.test.ts server/security.test.ts server/public-content.test.ts",
    "admin:hash": "node --import tsx scripts/hash-admin-password.ts",
    "db:backup": "node --import tsx scripts/backup-runtime-db.ts",
    "check": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
